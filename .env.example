# OpenAI (cheapest sensible models — protect the ~$10 budget)
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Hard cap on generated tokens per answer (lower = cheaper)
OPENAI_MAX_TOKENS=256

# LangSmith (optional tracing)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=myRAG

# Supabase (Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# Auth / JWT
# decoder = passlib scheme, e.g. bcrypt
decoder=bcrypt
ALGORITHM=HS256
# Generate with: openssl rand -hex 32
SECERET_KEY=change_me_to_a_long_random_hex_string
ACCESS_TOKEN_EXPIRE=60

# CORS: comma-separated allowed frontend origins.
# Local dev can use "*"; in production set your real domain(s):
# CORS_ORIGINS=https://your-frontend.vercel.app
CORS_ORIGINS=*

# ——— Rate limiting (slowapi syntax "count/period", stack with ";") ———
RATE_LIMIT_ENABLED=true
# /chat is the expensive LLM endpoint — keyed per authenticated user (else IP)
CHAT_RATE_LIMIT=10/minute;200/day
# /login + /createuser — per IP, to blunt brute force
AUTH_RATE_LIMIT=5/minute

# ——— Budget guardrail (global daily cap across all users) ———
BUDGET_ENABLED=true
# Max chat/LLM calls per day before returning a friendly 503
DAILY_CHAT_LIMIT=200

# Max characters allowed in a single question (~200 tokens). Longer inputs are
# rejected with a 400 before any OpenAI spend.
MAX_PROMPT_CHARS=800
